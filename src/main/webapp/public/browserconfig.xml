<?xml version="1.0" encoding="utf-8"?>
<browserconfig>
    <msapplication>
        <!-- Windows 10 tile configuration for Microsoft Edge -->
        <tile>
            <!-- Primary tile color matching Material-UI primary theme -->
            <TileColor>#1976d2</TileColor>
            
            <!-- Small tile (70x70) -->
            <square70x70logo src="/icons/tile-70x70.png"/>
            
            <!-- Medium tile (150x150) -->
            <square150x150logo src="/icons/tile-150x150.png"/>
            
            <!-- Wide tile (310x150) -->
            <wide310x150logo src="/icons/tile-310x150.png"/>
            
            <!-- Large tile (310x310) -->
            <square310x310logo src="/icons/tile-310x310.png"/>
            
            <!-- CardDemo application branding -->
            <TileImage src="/icons/tile-150x150.png"/>
            
            <!-- Windows Start menu tile text color -->
            <TileTextColor>#ffffff</TileTextColor>
            
            <!-- Badge notification support -->
            <badge>
                <polling>
                    <frequency>30</frequency>
                    <uris>
                        <uri src="/api/v1/notifications/badge"/>
                    </uris>
                </polling>
            </badge>
            
            <!-- Live tile notification polling -->
            <notification>
                <polling>
                    <frequency>30</frequency>
                    <uris>
                        <uri src="/api/v1/notifications/tile"/>
                    </uris>
                </polling>
            </notification>
        </tile>
        
        <!-- Windows desktop integration settings -->
        <notification>
            <!-- Toast notification settings -->
            <toast>
                <template>ToastText02</template>
                <sound>default</sound>
                <duration>long</duration>
            </toast>
            
            <!-- Notification polling configuration -->
            <polling>
                <frequency>30</frequency>
                <uris>
                    <uri src="/api/v1/notifications/toast"/>
                </uris>
            </polling>
        </notification>
        
        <!-- PWA-specific Windows integration -->
        <navbutton-color>#1976d2</navbutton-color>
        <starturl>/</starturl>
        
        <!-- Windows Jump List integration -->
        <jumplist>
            <task>
                <name>Account Management</name>
                <action-uri>/account-view</action-uri>
                <icon-uri>/icons/account-icon.png</icon-uri>
            </task>
            <task>
                <name>Card Management</name>
                <action-uri>/card-list</action-uri>
                <icon-uri>/icons/card-icon.png</icon-uri>
            </task>
            <task>
                <name>Transaction History</name>
                <action-uri>/transaction-list</action-uri>
                <icon-uri>/icons/transaction-icon.png</icon-uri>
            </task>
            <task>
                <name>Bill Payment</name>
                <action-uri>/bill-payment</action-uri>
                <icon-uri>/icons/payment-icon.png</icon-uri>
            </task>
        </jumplist>
        
        <!-- Windows taskbar integration -->
        <taskbar>
            <overlay-icon src="/icons/overlay-icon.png"/>
            <progress-indicator>
                <color>#4caf50</color>
            </progress-indicator>
            <thumbnail-toolbar>
                <button>
                    <tooltip>New Transaction</tooltip>
                    <icon src="/icons/new-transaction.png"/>
                    <action>/transaction-add</action>
                </button>
                <button>
                    <tooltip>Account Summary</tooltip>
                    <icon src="/icons/account-summary.png"/>
                    <action>/account-view</action>
                </button>
            </thumbnail-toolbar>
        </taskbar>
        
        <!-- Windows 10 app theming -->
        <theme>
            <accentcolor>#1976d2</accentcolor>
            <backgroundcolor>#ffffff</backgroundcolor>
            <foregroundcolor>#424242</foregroundcolor>
            <alternatecolor>#ffc107</alternatecolor>
            <errorcolor>#f44336</errorcolor>
            <successcolor>#4caf50</successcolor>
            <warningcolor>#ff9800</warningcolor>
            <infocolor>#26c6da</infocolor>
        </theme>
        
        <!-- Microsoft Edge PWA installation settings -->
        <pwa>
            <installation>
                <display>standalone</display>
                <orientation>portrait</orientation>
                <theme-color>#1976d2</theme-color>
                <background-color>#ffffff</background-color>
                <start-url>/</start-url>
                <scope>/</scope>
                <categories>
                    <category>finance</category>
                    <category>business</category>
                    <category>productivity</category>
                </categories>
            </installation>
            
            <!-- Edge-specific features -->
            <edge-features>
                <share-target>true</share-target>
                <protocol-handlers>
                    <protocol scheme="carddemo" url="/handle-protocol?scheme=%s"/>
                </protocol-handlers>
                <shortcuts>
                    <shortcut>
                        <name>Quick Balance</name>
                        <url>/account-view</url>
                        <icons>
                            <icon src="/icons/balance-shortcut.png" sizes="96x96"/>
                        </icons>
                    </shortcut>
                    <shortcut>
                        <name>Pay Bill</name>
                        <url>/bill-payment</url>
                        <icons>
                            <icon src="/icons/payment-shortcut.png" sizes="96x96"/>
                        </icons>
                    </shortcut>
                </shortcuts>
            </edge-features>
        </pwa>
        
        <!-- Windows security and privacy settings -->
        <security>
            <trusted-domains>
                <domain>localhost</domain>
                <domain>carddemo.local</domain>
            </trusted-domains>
            <ssl-required>true</ssl-required>
            <data-protection>
                <level>high</level>
                <encryption>true</encryption>
            </data-protection>
        </security>
        
        <!-- Windows accessibility features -->
        <accessibility>
            <high-contrast>true</high-contrast>
            <screen-reader>true</screen-reader>
            <keyboard-navigation>true</keyboard-navigation>
            <focus-indicators>true</focus-indicators>
            <zoom-support>true</zoom-support>
            <text-scaling>true</text-scaling>
        </accessibility>
        
        <!-- Windows performance optimization -->
        <performance>
            <preload>
                <resource type="stylesheet" href="/css/material-ui.css"/>
                <resource type="script" href="/js/react-bundle.js"/>
                <resource type="font" href="/fonts/roboto.woff2"/>
            </preload>
            <caching>
                <static-resources>
                    <cache-duration>86400</cache-duration>
                </static-resources>
                <api-responses>
                    <cache-duration>300</cache-duration>
                </api-responses>
            </caching>
        </performance>
    </msapplication>
</browserconfig>