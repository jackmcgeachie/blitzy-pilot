{
  "compilerOptions": {
    // Target ES2018 for modern browser support while maintaining compatibility
    "target": "ES2018",
    // Use ES2020 for module capabilities and dynamic imports
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    // Enable all strict type checking options for enterprise-grade code quality
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    
    // Module system configuration for Node.js and React ecosystem compatibility
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    
    // JSX configuration for React 18.x functional components with hooks
    "jsx": "react-jsx",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    
    // Enable decorators for potential future use with dependency injection
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    
    // Output configuration for webpack integration
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    
    // Path mapping for clean import statements across component hierarchy
    "paths": {
      "@/*": ["*"],
      "@/components/*": ["components/*"],
      "@/pages/*": ["pages/*"],
      "@/hooks/*": ["hooks/*"],
      "@/utils/*": ["utils/*"],
      "@/types/*": ["types/*"],
      "@/store/*": ["store/*"],
      "@/services/*": ["services/*"],
      "@/constants/*": ["constants/*"],
      "@/styles/*": ["styles/*"],
      "@/assets/*": ["assets/*"],
      "@/config/*": ["config/*"],
      "@/schemas/*": ["schemas/*"],
      "@/tests/*": ["tests/*"],
      
      // BMS screen replacement component paths
      "@/screens/auth/*": ["components/screens/auth/*"],
      "@/screens/menu/*": ["components/screens/menu/*"],
      "@/screens/account/*": ["components/screens/account/*"],
      "@/screens/card/*": ["components/screens/card/*"],
      "@/screens/transaction/*": ["components/screens/transaction/*"],
      "@/screens/payment/*": ["components/screens/payment/*"],
      "@/screens/user/*": ["components/screens/user/*"],
      "@/screens/report/*": ["components/screens/report/*"],
      
      // Redux state management paths
      "@/store/slices/*": ["store/slices/*"],
      "@/store/middleware/*": ["store/middleware/*"],
      "@/store/selectors/*": ["store/selectors/*"],
      "@/store/types/*": ["store/types/*"],
      
      // API integration paths
      "@/api/*": ["services/api/*"],
      "@/api/auth/*": ["services/api/auth/*"],
      "@/api/account/*": ["services/api/account/*"],
      "@/api/card/*": ["services/api/card/*"],
      "@/api/transaction/*": ["services/api/transaction/*"],
      "@/api/payment/*": ["services/api/payment/*"],
      "@/api/user/*": ["services/api/user/*"],
      "@/api/report/*": ["services/api/report/*"],
      
      // Validation schema paths for Formik/Yup integration
      "@/validation/*": ["schemas/validation/*"],
      "@/validation/auth/*": ["schemas/validation/auth/*"],
      "@/validation/account/*": ["schemas/validation/account/*"],
      "@/validation/card/*": ["schemas/validation/card/*"],
      "@/validation/transaction/*": ["schemas/validation/transaction/*"],
      "@/validation/payment/*": ["schemas/validation/payment/*"],
      "@/validation/user/*": ["schemas/validation/user/*"],
      
      // Type definitions for COBOL-to-TypeScript mappings
      "@/types/cobol/*": ["types/cobol/*"],
      "@/types/api/*": ["types/api/*"],
      "@/types/forms/*": ["types/forms/*"],
      "@/types/state/*": ["types/state/*"],
      "@/types/navigation/*": ["types/navigation/*"]
    },
    
    // TypeScript plugin configuration
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    
    // Additional type checking configuration
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "alwaysStrict": true,
    "noPropertyAccessFromIndexSignature": true,
    "useDefineForClassFields": true,
    "importsNotUsedAsValues": "error",
    "preserveValueImports": true,
    
    // Emit configuration for debugging and development
    "inlineSourceMap": false,
    "inlineSources": false,
    "mapRoot": "./maps",
    "sourceRoot": "./src",
    
    // Module detection and resolution
    "moduleDetection": "force",
    "allowImportingTsExtensions": false,
    "allowArbitraryExtensions": false,
    "customConditions": [],
    
    // Performance and build optimization
    "assumeChangesOnlyAffectDirectDependencies": true,
    "generateCpuProfile": false,
    "disableReferencedProjectLoad": false,
    "disableSolutionSearching": false,
    "disableSourceOfProjectReferenceRedirect": false,
    
    // Webpack and build tool compatibility
    "allowUmdGlobalAccess": false,
    "noEmit": true,
    "importHelpers": true,
    "downlevelIteration": true,
    "newLine": "lf",
    "stripInternal": true,
    
    // React-specific optimizations
    "jsxImportSource": "react"
  },
  
  // Include all TypeScript and React files for compilation
  "include": [
    "src/**/*",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.json",
    "src/**/*.d.ts",
    "src/types/**/*.ts",
    "src/components/**/*.tsx",
    "src/pages/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/utils/**/*.ts",
    "src/services/**/*.ts",
    "src/store/**/*.ts",
    "src/schemas/**/*.ts",
    "src/constants/**/*.ts",
    "src/config/**/*.ts",
    "src/tests/**/*.ts",
    "src/tests/**/*.tsx",
    
    // Include all 17 React components replacing BMS screens
    "src/components/screens/auth/**/*.tsx",
    "src/components/screens/menu/**/*.tsx",
    "src/components/screens/account/**/*.tsx",
    "src/components/screens/card/**/*.tsx",
    "src/components/screens/transaction/**/*.tsx",
    "src/components/screens/payment/**/*.tsx",
    "src/components/screens/user/**/*.tsx",
    "src/components/screens/report/**/*.tsx",
    
    // Include shared UI components
    "src/components/common/**/*.tsx",
    "src/components/layout/**/*.tsx",
    "src/components/forms/**/*.tsx",
    "src/components/ui/**/*.tsx",
    
    // Include Redux state management files
    "src/store/slices/**/*.ts",
    "src/store/middleware/**/*.ts",
    "src/store/selectors/**/*.ts",
    "src/store/types/**/*.ts",
    
    // Include API service files
    "src/services/api/**/*.ts",
    "src/services/auth/**/*.ts",
    "src/services/validation/**/*.ts",
    "src/services/utils/**/*.ts",
    
    // Include validation schemas
    "src/schemas/validation/**/*.ts",
    "src/schemas/api/**/*.ts",
    "src/schemas/forms/**/*.ts",
    
    // Include type definitions
    "src/types/cobol/**/*.ts",
    "src/types/api/**/*.ts",
    "src/types/forms/**/*.ts",
    "src/types/state/**/*.ts",
    "src/types/navigation/**/*.ts",
    "src/types/components/**/*.ts"
  ],
  
  // Exclude files that should not be compiled by TypeScript
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "public",
    "*.config.js",
    "*.config.ts",
    "**/*.test.js",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/setupTests.js",
    "src/reportWebVitals.js",
    "webpack.config.js",
    "jest.config.js",
    "babel.config.js",
    ".eslintrc.js",
    "prettier.config.js",
    "stylelint.config.js",
    "*.d.ts.map",
    "src/**/*.stories.tsx",
    "src/**/*.stories.ts",
    "src/mocks/**/*",
    "src/storybook/**/*",
    "src/cypress/**/*",
    "src/e2e/**/*"
  ],
  
  // TypeScript references for project composition (if needed)
  "references": [],
  
  // Compiler diagnostics configuration
  "compileOnSave": false,
  "watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "synchronousWatchDirectory": true,
    "excludeDirectories": ["**/node_modules", "**/dist", "**/build"]
  },
  
  // TypeScript 5.x specific configuration for React 18.x
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "compilerOptions": {
      "module": "ESNext",
      "target": "ES2018"
    }
  }
}