<?xml version="1.0" encoding="UTF-8"?>
<!--
  CardDemo Application Logback Configuration
  
  This configuration provides comprehensive enterprise-grade logging for the CardDemo
  credit card management system migrated from IBM mainframe COBOL/CICS/VSAM to
  Java/Spring Boot architecture.
  
  Key Features:
  - Structured JSON logging for enterprise log aggregation (Fluent Bit → Elasticsearch → Kibana)
  - Comprehensive audit trail generation replacing traditional SMF records
  - Separate log appenders for application, audit, security, and performance events
  - Correlation ID support for distributed tracing across microservices
  - Configurable log retention policies for compliance requirements
  - Environment-specific configurations (development, staging, production)
  - Integration with Spring Boot application properties
  - MDC (Mapped Diagnostic Context) for user context and session tracking
  
  Author: Blitzy Development Team
  Version: 1.0
  Date: 2024-01-15
-->

<configuration>
    <!-- ========================================================================= -->
    <!-- CONFIGURATION VARIABLES AND PROPERTIES                                   -->
    <!-- ========================================================================= -->
    
    <!-- Spring Boot configuration property resolution -->
    <springProfile name="!test">
        <property name="APPLICATION_NAME" value="${spring.application.name:-carddemo-application}"/>
        <property name="LOG_LEVEL_ROOT" value="${logging.level.root:-INFO}"/>
        <property name="LOG_LEVEL_APP" value="${logging.level.com.carddemo:-INFO}"/>
        <property name="LOG_LEVEL_SECURITY" value="${logging.level.org.springframework.security:-INFO}"/>
        <property name="LOG_FILE_NAME" value="${logging.file.name:-logs/carddemo.log}"/>
        <property name="LOG_FILE_MAX_SIZE" value="${logging.file.max-size:-100MB}"/>
        <property name="LOG_FILE_MAX_HISTORY" value="${logging.file.max-history:-30}"/>
        <property name="LOG_FILE_TOTAL_SIZE_CAP" value="${logging.file.total-size-cap:-1GB}"/>
        <property name="ENVIRONMENT" value="${spring.profiles.active:-development}"/>
    </springProfile>
    
    <!-- Test profile minimal configuration -->
    <springProfile name="test">
        <property name="APPLICATION_NAME" value="carddemo-test"/>
        <property name="LOG_LEVEL_ROOT" value="WARN"/>
        <property name="LOG_LEVEL_APP" value="DEBUG"/>
        <property name="ENVIRONMENT" value="test"/>
    </springProfile>
    
    <!-- Common logging patterns -->
    <property name="CONSOLE_LOG_PATTERN" 
              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>
    
    <!-- Correlation ID pattern for distributed tracing -->
    <property name="CORRELATION_ID_PATTERN" 
              value="[%X{correlationId:-NO_CORRELATION_ID}]"/>
    
    <!-- User context pattern for audit trails -->
    <property name="USER_CONTEXT_PATTERN" 
              value="[%X{userId:-ANONYMOUS}|%X{username:-UNKNOWN}|%X{sessionId:-NO_SESSION}]"/>
    
    <!-- Performance metrics pattern -->
    <property name="PERFORMANCE_PATTERN" 
              value="[%X{requestId:-NO_REQUEST}|%X{duration:-0}ms|%X{endpoint:-UNKNOWN}]"/>
    
    <!-- ========================================================================= -->
    <!-- JSON ENCODER CONFIGURATION                                               -->
    <!-- ========================================================================= -->
    
    <!-- JSON Encoder for structured logging -->
    <encoder name="JSON_ENCODER" class="net.logstash.logback.encoder.LogstashEncoder">
        <includeContext>true</includeContext>
        <includeMdc>true</includeMdc>
        <customFields>{"application":"${APPLICATION_NAME}","environment":"${ENVIRONMENT}"}</customFields>
        <fieldNames>
            <timestamp>@timestamp</timestamp>
            <version>@version</version>
            <level>level</level>
            <thread>thread</thread>
            <mdc>mdc</mdc>
            <logger>logger</logger>
            <message>message</message>
            <levelValue>level_value</levelValue>
        </fieldNames>
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
        <timeZone>UTC</timeZone>
        <!-- Mask sensitive data in logs -->
        <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
            <defaultMask>****</defaultMask>
            <path>password</path>
            <path>cardNumber</path>
            <path>ssn</path>
            <path>cvv</path>
            <path>pin</path>
            <path>accountNumber</path>
        </jsonGeneratorDecorator>
    </encoder>
    
    <!-- ========================================================================= -->
    <!-- CONSOLE APPENDER FOR DEVELOPMENT                                          -->
    <!-- ========================================================================= -->
    
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>DEBUG</level>
        </filter>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- APPLICATION APPENDER - GENERAL APPLICATION LOGS                          -->
    <!-- ========================================================================= -->
    
    <appender name="APPLICATION_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"log_type":"application","application":"${APPLICATION_NAME}","environment":"${ENVIRONMENT}"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <level>level</level>
                <thread>thread</thread>
                <mdc>mdc</mdc>
                <logger>logger</logger>
                <message>message</message>
                <stack_trace>stack_trace</stack_trace>
            </fieldNames>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            <timeZone>UTC</timeZone>
            <!-- Mask sensitive data -->
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>****</defaultMask>
                <path>password</path>
                <path>cardNumber</path>
                <path>ssn</path>
                <path>cvv</path>
                <path>pin</path>
                <path>accountNumber</path>
            </jsonGeneratorDecorator>
        </encoder>
        
        <!-- Rolling policy for application logs -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        
        <!-- Filter to exclude audit and security events -->
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator>
                <expression>
                    logger.contains("com.carddemo.audit") || 
                    logger.contains("org.springframework.security") || 
                    message.contains("AUDIT_RECORD:") || 
                    message.contains("SECURITY_EVENT:")
                </expression>
            </evaluator>
            <onMismatch>NEUTRAL</onMismatch>
            <onMatch>DENY</onMatch>
        </filter>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- AUDIT APPENDER - COMPREHENSIVE AUDIT TRAIL LOGGING                       -->
    <!-- ========================================================================= -->
    
    <appender name="AUDIT_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/audit.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"log_type":"audit","application":"${APPLICATION_NAME}","environment":"${ENVIRONMENT}","compliance_category":"FINANCIAL_AUDIT"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <level>level</level>
                <thread>thread</thread>
                <mdc>mdc</mdc>
                <logger>logger</logger>
                <message>message</message>
                <arguments>arguments</arguments>
            </fieldNames>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSSSSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <!-- Enhanced masking for audit logs -->
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>****</defaultMask>
                <path>password</path>
                <path>cardNumber</path>
                <path>ssn</path>
                <path>cvv</path>
                <path>pin</path>
                <path>accountNumber</path>
                <path>password_hash</path>
                <path>jwt_token</path>
            </jsonGeneratorDecorator>
        </encoder>
        
        <!-- Extended retention policy for compliance - 7 years -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/audit/audit.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>2557</maxHistory> <!-- 7 years * 365 days -->
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        
        <!-- Filter for audit events only -->
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator>
                <expression>
                    logger.contains("com.carddemo.audit") || 
                    message.contains("AUDIT_RECORD:")
                </expression>
            </evaluator>
            <onMismatch>DENY</onMismatch>
            <onMatch>ACCEPT</onMatch>
        </filter>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- SECURITY APPENDER - SECURITY EVENT LOGGING                               -->
    <!-- ========================================================================= -->
    
    <appender name="SECURITY_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/security.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"log_type":"security","application":"${APPLICATION_NAME}","environment":"${ENVIRONMENT}","security_domain":"AUTHENTICATION_AUTHORIZATION"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <level>level</level>
                <thread>thread</thread>
                <mdc>mdc</mdc>
                <logger>logger</logger>
                <message>message</message>
                <arguments>arguments</arguments>
                <stack_trace>stack_trace</stack_trace>
            </fieldNames>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSSSSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <!-- Security-specific masking -->
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>****</defaultMask>
                <path>password</path>
                <path>cardNumber</path>
                <path>ssn</path>
                <path>cvv</path>
                <path>pin</path>
                <path>accountNumber</path>
                <path>password_hash</path>
                <path>jwt_token</path>
                <path>session_id</path>
            </jsonGeneratorDecorator>
        </encoder>
        
        <!-- Extended retention for security logs - 3 years -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/security/security.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>1095</maxHistory> <!-- 3 years * 365 days -->
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        
        <!-- Filter for security events -->
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator>
                <expression>
                    logger.contains("org.springframework.security") || 
                    logger.contains("com.carddemo.auth") || 
                    logger.contains("com.carddemo.security") ||
                    message.contains("SECURITY_EVENT:") ||
                    message.contains("Authentication") ||
                    message.contains("Authorization") ||
                    message.contains("Login") ||
                    message.contains("Logout") ||
                    message.contains("JWT") ||
                    message.contains("Session")
                </expression>
            </evaluator>
            <onMismatch>DENY</onMismatch>
            <onMatch>ACCEPT</onMatch>
        </filter>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- PERFORMANCE APPENDER - PERFORMANCE METRICS AND SLA MONITORING           -->
    <!-- ========================================================================= -->
    
    <appender name="PERFORMANCE_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/performance.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"log_type":"performance","application":"${APPLICATION_NAME}","environment":"${ENVIRONMENT}","sla_target":"200ms"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <level>level</level>
                <thread>thread</thread>
                <mdc>mdc</mdc>
                <logger>logger</logger>
                <message>message</message>
                <arguments>arguments</arguments>
            </fieldNames>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSSSSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
        </encoder>
        
        <!-- Rolling policy for performance logs -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/performance/performance.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory> <!-- 90 days retention -->
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        
        <!-- Filter for performance-related events -->
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator>
                <expression>
                    logger.contains("com.carddemo.performance") || 
                    logger.contains("io.micrometer") || 
                    message.contains("PERFORMANCE_METRIC:") ||
                    message.contains("Response time") ||
                    message.contains("Transaction throughput") ||
                    message.contains("Database query time") ||
                    message.contains("Batch processing time") ||
                    (mdc != null &amp;&amp; mdc.get("duration") != null)
                </expression>
            </evaluator>
            <onMismatch>DENY</onMismatch>
            <onMatch>ACCEPT</onMatch>
        </filter>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- ERROR APPENDER - CRITICAL ERROR LOGGING                                  -->
    <!-- ========================================================================= -->
    
    <appender name="ERROR_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/errors.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"log_type":"error","application":"${APPLICATION_NAME}","environment":"${ENVIRONMENT}","severity":"ERROR"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <level>level</level>
                <thread>thread</thread>
                <mdc>mdc</mdc>
                <logger>logger</logger>
                <message>message</message>
                <arguments>arguments</arguments>
                <stack_trace>stack_trace</stack_trace>
            </fieldNames>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSSSSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
        </encoder>
        
        <!-- Rolling policy for error logs -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/errors/errors.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>365</maxHistory> <!-- 1 year retention -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        
        <!-- Filter for ERROR and WARN levels only -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- ASYNC APPENDER WRAPPERS FOR PERFORMANCE                                  -->
    <!-- ========================================================================= -->
    
    <!-- Async wrapper for APPLICATION_APPENDER -->
    <appender name="ASYNC_APPLICATION" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="APPLICATION_APPENDER"/>
    </appender>
    
    <!-- Async wrapper for AUDIT_APPENDER -->
    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="AUDIT_APPENDER"/>
    </appender>
    
    <!-- Async wrapper for SECURITY_APPENDER -->
    <appender name="ASYNC_SECURITY" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="SECURITY_APPENDER"/>
    </appender>
    
    <!-- Async wrapper for PERFORMANCE_APPENDER -->
    <appender name="ASYNC_PERFORMANCE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="PERFORMANCE_APPENDER"/>
    </appender>
    
    <!-- ========================================================================= -->
    <!-- LOGGER CONFIGURATION                                                     -->
    <!-- ========================================================================= -->
    
    <!-- AuditService logger - dedicated audit appender -->
    <logger name="com.carddemo.audit.AuditService" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_AUDIT"/>
    </logger>
    
    <!-- Security-related loggers -->
    <logger name="org.springframework.security" level="${LOG_LEVEL_SECURITY}" additivity="false">
        <appender-ref ref="ASYNC_SECURITY"/>
    </logger>
    
    <logger name="com.carddemo.auth" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_SECURITY"/>
    </logger>
    
    <logger name="com.carddemo.session" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_SECURITY"/>
    </logger>
    
    <!-- Performance monitoring loggers -->
    <logger name="com.carddemo.performance" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <logger name="io.micrometer" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <!-- Database performance logging -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <!-- HikariCP connection pool monitoring -->
    <logger name="com.zaxxer.hikari" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <!-- Redis connection monitoring -->
    <logger name="io.lettuce.core" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <!-- Spring Batch monitoring -->
    <logger name="org.springframework.batch" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_PERFORMANCE"/>
    </logger>
    
    <!-- Application-specific loggers -->
    <logger name="com.carddemo" level="${LOG_LEVEL_APP}" additivity="false">
        <appender-ref ref="ASYNC_APPLICATION"/>
    </logger>
    
    <!-- Spring Framework loggers -->
    <logger name="org.springframework" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_APPLICATION"/>
    </logger>
    
    <logger name="org.springframework.web" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_APPLICATION"/>
    </logger>
    
    <!-- Flyway database migration logging -->
    <logger name="org.flywaydb" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_APPLICATION"/>
    </logger>
    
    <!-- ========================================================================= -->
    <!-- ENVIRONMENT-SPECIFIC CONFIGURATIONS                                      -->
    <!-- ========================================================================= -->
    
    <!-- DEVELOPMENT PROFILE -->
    <springProfile name="development">
        <logger name="com.carddemo" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_APPLICATION"/>
        </logger>
        
        <logger name="org.springframework.security" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_SECURITY"/>
        </logger>
        
        <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_PERFORMANCE"/>
        </logger>
        
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_PERFORMANCE"/>
        </logger>
        
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_APPLICATION"/>
            <appender-ref ref="ERROR_APPENDER"/>
        </root>
    </springProfile>
    
    <!-- STAGING PROFILE -->
    <springProfile name="staging">
        <logger name="com.carddemo" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_APPLICATION"/>
        </logger>
        
        <logger name="org.springframework.security" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_SECURITY"/>
        </logger>
        
        <root level="INFO">
            <appender-ref ref="ASYNC_APPLICATION"/>
            <appender-ref ref="ERROR_APPENDER"/>
        </root>
    </springProfile>
    
    <!-- PRODUCTION PROFILE -->
    <springProfile name="production">
        <logger name="com.carddemo" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_APPLICATION"/>
        </logger>
        
        <logger name="org.springframework.security" level="WARN" additivity="false">
            <appender-ref ref="ASYNC_SECURITY"/>
        </logger>
        
        <logger name="org.hibernate.SQL" level="WARN" additivity="false">
            <appender-ref ref="ASYNC_PERFORMANCE"/>
        </logger>
        
        <root level="WARN">
            <appender-ref ref="ASYNC_APPLICATION"/>
            <appender-ref ref="ERROR_APPENDER"/>
        </root>
    </springProfile>
    
    <!-- TEST PROFILE -->
    <springProfile name="test">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
    
    <!-- ========================================================================= -->
    <!-- ROOT LOGGER CONFIGURATION                                                -->
    <!-- ========================================================================= -->
    
    <!-- Default root logger configuration -->
    <springProfile name="!development,!staging,!production,!test">
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_APPLICATION"/>
            <appender-ref ref="ERROR_APPENDER"/>
        </root>
    </springProfile>
    
    <!-- ========================================================================= -->
    <!-- CORRELATION ID SUPPORT FOR DISTRIBUTED TRACING                          -->
    <!-- ========================================================================= -->
    
    <!-- MDC inserting filter for correlation IDs -->
    <turboFilter class="ch.qos.logback.classic.turbo.MDCFilter">
        <MDCKey>correlationId</MDCKey>
        <value>NO_CORRELATION_ID</value>
        <onMatch>NEUTRAL</onMatch>
        <onMismatch>DENY</onMismatch>
    </turboFilter>
    
    <!-- ========================================================================= -->
    <!-- LOG ROTATION POLICY CONFIGURATION                                        -->
    <!-- ========================================================================= -->
    
    <!-- 
    Log Rotation Policies Summary:
    
    APPLICATION_APPENDER:
    - Rolling: Daily + 100MB size limit
    - Retention: 30 days
    - Total size cap: 1GB
    
    AUDIT_APPENDER:
    - Rolling: Daily + 50MB size limit
    - Retention: 7 years (2557 days) for compliance
    - Total size cap: 10GB
    
    SECURITY_APPENDER:
    - Rolling: Daily + 50MB size limit
    - Retention: 3 years (1095 days)
    - Total size cap: 5GB
    
    PERFORMANCE_APPENDER:
    - Rolling: Daily + 100MB size limit
    - Retention: 90 days
    - Total size cap: 2GB
    
    ERROR_APPENDER:
    - Rolling: Daily + 50MB size limit
    - Retention: 365 days
    - Total size cap: 1GB
    -->
    
    <!-- ========================================================================= -->
    <!-- RETENTION POLICY CONFIGURATION                                           -->
    <!-- ========================================================================= -->
    
    <!-- 
    Retention Policies for Compliance:
    
    1. Audit Logs: 7 years (2557 days) - Financial compliance requirements
    2. Security Logs: 3 years (1095 days) - Security incident investigation
    3. Performance Logs: 90 days - Performance monitoring and optimization
    4. Application Logs: 30 days - General operational troubleshooting
    5. Error Logs: 1 year (365 days) - Error pattern analysis and resolution
    
    These retention periods align with:
    - SOX compliance requirements
    - PCI DSS audit trail requirements
    - Financial services regulatory requirements
    - Enterprise security monitoring standards
    -->
    
</configuration>